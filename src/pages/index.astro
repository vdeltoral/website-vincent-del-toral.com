---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Vincent Del Toral — Software Engineering Consulting"
  description="Good software, right when you need it. Custom apps, web scraping, automation, and AI integrations."
>
  <!-- Hero -->
  <section class="hero">
    <div class="reveal">
      <h1>Good software, right when you need it.</h1>
      <p>I'm Vincent — a software engineer who works directly with business owners to build the tools they actually need. No overhead or long timelines. Just one senior developer, fully focused on your project.</p>
      <div class="hero-ctas">
        <a href="/work" class="btn btn-primary">See What I Do</a>
        <a href="/contact" class="btn btn-secondary">Get In Touch</a>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <div class="section-alt">
    <section class="section">
      <div class="reveal">
        <h2>What I can build for you</h2>
      </div>
      <div class="card-grid">
        <div class="card reveal" data-delay="0">
          <h3>You need an app for your business.</h3>
          <p>Booking systems, dashboards, payment integration — the kind of thing that replaces spreadsheets and manual processes.</p>
        </div>
        <div class="card reveal" data-delay="100">
          <h3>You need data collected or monitored.</h3>
          <p>Web scraping, price tracking, automated reports — set it up once, let it run.</p>
        </div>
        <div class="card reveal" data-delay="200">
          <h3>You want to put AI to work.</h3>
          <p>AI-powered tools for your customers or team — chatbots, assistants, smart search.</p>
        </div>
      </div>
    </section>
  </div>

  <!-- CTA Banner -->
  <section class="cta-banner reveal">
    <p>Not sure what you need? That's fine.</p>
    <a href="/contact" class="btn btn-primary">Let's Figure It Out</a>
  </section>
</BaseLayout>
